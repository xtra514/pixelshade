flowchart TD
    Start([New Match]) --> IsWinOrLoss{Match Result?}
    
    IsWinOrLoss -- Loss --> IsLoss(It's a Loss)
    IsLoss --> TrophyCheckLoss{Brawler Trophies?}
    
    TrophyCheckLoss -- "<= 1000" --> IncStreak[Add +1 to Loss Count]
    IncStreak --> CheckStreak{Loss Count >= 3?}
    CheckStreak -- "Yes" --> ArmTrap[[ARM THE TRAP]]
    CheckStreak -- "No" --> Wait1([Wait for Next Match])
    
    TrophyCheckLoss -- "> 1000" --> IsPrestigeFloor{Exact Multiple of 1000?}
    IsPrestigeFloor -- "Yes" --> FloorHit[0 Trophies Lost. Streak PAUSED.]
    FloorHit --> WaitFloor([Wait for Next Match])
    IsPrestigeFloor -- "No" --> ResetAll[Lost trophies. Reset Streak to 0.]
    ResetAll --> DisarmTrap[[DISARM TRAP]]
    DisarmTrap --> Wait2([Wait for Next Match])
    
    IsWinOrLoss -- Win --> IsWin(It's a Win)
    IsWin --> CheckTrap{Is Trap Armed?}
    
    CheckTrap -- "Yes" --> TrophyCheckWin{Brawler Trophies?}
    TrophyCheckWin -- "<= 1999" --> ExploitDetected[/EXPLOIT DETECTED!\]
    ExploitDetected --> StripTrophies(Strip trophies from Grind Points)
    StripTrophies --> ResetAll2[Reset Streak to 0]
    ResetAll2 --> DisarmTrap2[[DISARM TRAP]]
    
    TrophyCheckWin -- "> 1999" --> NormalWin2(Normal Win)
    NormalWin2 --> ResetAll3[Reset Streak to 0]
    ResetAll3 --> DisarmTrap3[[DISARM TRAP]]

    CheckTrap -- "No" --> NormalWin1(Normal Win)
    NormalWin1 --> ResetAll4[Reset Streak to 0]
    ResetAll4 --> DisarmTrap4[[DISARM TRAP]]
